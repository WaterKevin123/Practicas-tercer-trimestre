#include <SPI.h>
#include <TFT_eSPI.h>

// ===== TFT =====
TFT_eSPI tft = TFT_eSPI();

void setup() {

  // iniciar pantalla
  tft.init();

  // horizontal
  tft.setRotation(1);

  // fondo
  tft.fillScreen(TFT_BLACK);

  // ===== TITULO =====
  tft.setTextColor(TFT_CYAN, TFT_BLACK);

  tft.setTextSize(3);

  tft.setCursor(40, 20);

  tft.println("INTEGRANTES");

  // línea decorativa
  tft.drawLine(20, 60, 300, 60, TFT_CYAN);

  // ===== NOMBRES =====
  tft.setTextColor(TFT_WHITE, TFT_BLACK);

  tft.setTextSize(2);

  tft.setCursor(40, 100);
  tft.println("DANIEL QUITO");

  tft.setCursor(40, 140);
  tft.println("KEVIN SACANCELA");

  tft.setCursor(40, 180);
  tft.println("MARCO PERALTA");

  // círculos decorativos
  tft.fillCircle(20, 110, 6, TFT_RED);

  tft.fillCircle(20, 150, 6, TFT_GREEN);

  tft.fillCircle(20, 190, 6, TFT_BLUE);
}

void loop() {

}
