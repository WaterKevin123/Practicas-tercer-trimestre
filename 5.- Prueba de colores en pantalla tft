#include <SPI.h>
#include <TFT_eSPI.h>

TFT_eSPI tft = TFT_eSPI();

void setup() {

  tft.init();

  // horizontal
  tft.setRotation(1);

  // fondo negro
  tft.fillScreen(TFT_BLACK);

  // cuadros de colores estáticos
  tft.fillRect(0, 0, 80, 135, TFT_RED);

  tft.fillRect(80, 0, 80, 135, TFT_GREEN);

  tft.fillRect(160, 0, 80, 135, TFT_BLUE);

  // texto
  tft.setTextColor(TFT_WHITE);

  tft.setTextSize(2);

  tft.setCursor(60, 100);

  tft.println("RGB TEST");
}

void loop() {

}
